library verilog;
use verilog.vl_types.all;
entity datapath is
    port(
        clk             : in     vl_logic;
        rst             : in     vl_logic;
        we              : in     vl_logic;
        rs1             : in     vl_logic_vector(1 downto 0);
        rs2             : in     vl_logic_vector(1 downto 0);
        rd              : in     vl_logic_vector(1 downto 0);
        op              : in     vl_logic_vector(2 downto 0)
    );
end datapath;
